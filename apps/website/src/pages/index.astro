---
// gmux landing page — dark, minimal, confident
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>gmux — monitor every agent, test runner, and process</title>
  <meta name="description" content="Keep tabs on every AI agent, test runner, and long-running process across your machines. Work from your desktop, steer from your phone." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">gmux</a>
      <div class="nav-links">
        <a href="/introduction">Docs</a>
        <a href="https://github.com/gmuxapp/gmux" class="nav-github">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Monitor every agent, test runner, and process</h1>
        <p class="hero-sub">
          Live terminals in the browser. Grouped by project.
          Status that tells you what needs attention.
          No tmux, no Electron — two binaries and a browser tab.
        </p>
        <div class="hero-actions">
          <a href="/quick-start" class="hero-cta">Get started</a>
          <a href="https://github.com/gmuxapp/gmux" class="hero-secondary">View on GitHub →</a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/hero.png" alt="gmux desktop and mobile interface showing test runners, AI agents, and terminal sessions grouped by project" width="1321" height="906" />
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <span class="footer-logo">gmux</span>
      <div class="footer-links">
        <a href="/introduction">Docs</a>
        <a href="https://github.com/gmuxapp/gmux">GitHub</a>
        <span class="footer-sep">·</span>
        <span class="footer-license">MIT License</span>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  /* ============================================
     gmux landing page
     Dark, minimal, confident
     ============================================ */

  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: oklch(13% 0.015 250);
    --bg-raised: oklch(16% 0.015 250);
    --bg-surface: oklch(19% 0.015 250);
    --text: oklch(88% 0.01 250);
    --text-secondary: oklch(65% 0.01 250);
    --text-muted: oklch(48% 0.01 250);
    --accent: oklch(72% 0.1 195);
    --border: oklch(22% 0.015 250);
    --border-subtle: oklch(19% 0.01 250);
    --green: oklch(72% 0.14 145);
    --amber: oklch(76% 0.14 85);
    --radius: 8px;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: 'Source Sans 3', 'Segoe UI', system-ui, sans-serif;
    color: var(--text);
    background: var(--bg);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1, h2, h3 {
    font-family: 'Instrument Sans', sans-serif;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }

  /* --- Nav --- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: oklch(13% 0.015 250 / 0.8);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    font-size: 22px;
    color: var(--text);
    letter-spacing: -0.04em;
  }
  .nav-logo:hover { text-decoration: none; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--text-secondary);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.15s;
  }
  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .nav-github {
    display: flex;
    align-items: center;
    color: var(--text-muted) !important;
  }
  .nav-github:hover { color: var(--text) !important; }

  /* --- Hero --- */
  .hero {
    flex: 1;
    display: flex;
    align-items: center;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(2rem, 4vw, 3rem);
  }

  .hero-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
  }

  .hero-text {
    max-width: 640px;
    margin-bottom: clamp(2.5rem, 4vw, 4rem);
  }

  .hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.3vw, 1.15rem);
    color: var(--text-secondary);
    max-width: 48ch;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .hero-cta {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--bg);
    background: var(--text);
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    transition: opacity 0.15s;
  }
  .hero-cta:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  .hero-secondary {
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .hero-secondary:hover {
    color: var(--text);
    text-decoration: none;
  }

  /* --- Hero Image --- */
  .hero-image {
    width: 100%;
    max-width: 1100px;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* --- Footer --- */
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    font-family: 'Instrument Sans', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-muted);
    letter-spacing: -0.04em;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.85rem;
  }
  .footer-links a { color: var(--text-secondary); }
  .footer-sep { color: var(--text-muted); }
  .footer-license { color: var(--text-muted); }

  /* --- Responsive --- */
  @media (max-width: 600px) {
    .hero h1 { font-size: 1.65rem; }
    .hero-actions { flex-direction: column; gap: 0.75rem; }
  }

  /* --- Entry animation --- */
  @media (prefers-reduced-motion: no-preference) {
    .hero-text { animation: fadeUp 0.5s ease-out both; }
    .hero-image { animation: fadeUp 0.6s 0.15s ease-out both; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>
